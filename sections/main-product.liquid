<div class="relative w-full min-h-screen pt-10 pb-24 px-4 sm:px-6 lg:px-12 bg-[#09090b] font-['Outfit'] antialiased" data-section-id="{{ section.id }}">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 relative z-20">
        
        <!-- Left: Premium Image Gallery -->
        <div class="w-full flex justify-center lg:justify-end relative">
            <div class="w-full max-w-xl pb-32">
                <div id="pdp-gallery">
                    <div id="pdp-main-wrap" class="relative width-full aspect-[4/5] bg-[#0d0d10] rounded-[20px] overflow-hidden border border-white/5 cursor-zoom-in">
                        <img id="pdp-main-img" src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}" class="w-full h-full object-cover object-top transition-opacity duration-500">
                        <div id="pdp-lens" class="absolute inset-0 pointer-events-none bg-white/5 opacity-0 transition-opacity"></div>
                        <div id="pdp-counter" class="absolute bottom-[14px] right-[14px] text-[10px] tracking-[0.15em] text-white/40 bg-black/50 backdrop-blur-md border border-white/10 rounded-full px-3 py-1">1 / {{ product.images.size }}</div>
                    </div>
                    <div id="pdp-thumbs" class="flex gap-2 mt-3 overflow-x-auto pb-1 scrollbar-hide">
                        {%- for image in product.images -%}
                          <div class="pdp-thumb flex-shrink-0 w-[72px] h-[88px] rounded-xl overflow-hidden border border-white/10 cursor-pointer opacity-60 hover:opacity-100 transition-all {% if forloop.first %}active border-white/50 opacity-100{% endif %}" data-index="{{ forloop.index0 }}">
                            <img src="{{ image.src | img_url: '150x' }}" class="w-full h-full object-cover">
                          </div>
                        {%- endfor -%}
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Product Details -->
        <div class="w-full flex items-start pt-8 lg:pt-0 relative">
            <div class="flex flex-col gap-8 max-w-md w-full sticky top-36 h-fit pb-32">
                <div>
                  <span class="text-[10px] tracking-[0.3em] text-zinc-500 uppercase font-semibold mb-2 block">{{ product.type | default: 'New Arrival' }}</span>
                  <h1 class="text-4xl md:text-5xl font-bold text-white tracking-widest uppercase leading-tight">{{ product.title }}</h1>
                  <p class="text-xl text-zinc-400 font-light mt-3">{{ product.price | money }}</p>
                </div>

                <div class="h-px w-full bg-white/5"></div>

                <!-- Form -->
                {%- form 'product', product -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  
                  <!-- Size Selector example -->
                  {%- unless product.has_only_default_variant -%}
                    <div class="flex flex-col gap-3 mb-6">
                      <p class="text-xs tracking-[0.2em] text-white uppercase">Size</p>
                      <div class="grid grid-cols-4 gap-3">
                        {%- for variant in product.variants -%}
                          <button type="button" class="variant-button py-3.5 border border-white/10 rounded-lg text-xs hover:border-white transition-colors bg-white/5 uppercase tracking-widest text-white {% if product.selected_or_first_available_variant.id == variant.id %}bg-white text-black font-semibold border-white{% endif %}" data-id="{{ variant.id }}">
                            {{ variant.title }}
                          </button>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- endunless -%}

                  <button type="submit" name="add" class="w-full bg-white text-black font-semibold py-4 px-6 rounded-full shadow-[0_0_30px_rgba(255,255,255,0.15)] hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] hover:scale-[1.02] active:scale-[0.98] uppercase tracking-[0.2em] text-xs transition-all duration-300">
                    Add to Cart
                  </button>
                {%- endform -%}

                <!-- Description -->
                <div class="flex flex-col border-t border-white/10 mt-2">
                    <div class="py-6 border-b border-white/5 flex justify-between items-center cursor-pointer group">
                        <h4 class="text-xs tracking-[0.2em] uppercase text-zinc-300">Product Info</h4>
                    </div>
                    <div class="py-4 text-zinc-400 font-light leading-relaxed prose prose-invert prose-sm">
                      {{ product.description }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
  .pdp-thumb.active { border-color: rgba(255,255,255,0.6); opacity: 1; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

{% schema %}
{
  "name": "Main Product",
  "settings": []
}
{% endschema %}
