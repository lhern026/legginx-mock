<section style="width:100%;background:#000;padding:88px 0 0;overflow:hidden;border-top:1px solid rgba(255,255,255,0.04);" class="font-['Outfit'] lgx-section-tight" data-section-id="{{ section.id }}">
  <div style="max-width:90rem;margin:0 auto;padding:0 24px;position:relative;">

    <!-- Ghost watermark -->
    <div style="overflow:hidden;margin-bottom:-clamp(28px,4vw,48px);pointer-events:none;user-select:none;line-height:1;" aria-hidden="true">
      <p style="font-size:clamp(6rem,20vw,18rem);font-weight:900;text-transform:uppercase;letter-spacing:-0.05em;color:rgba(255,255,255,0.035);line-height:0.82;">{{ section.settings.watermark | escape }}</p>
    </div>

    <!-- Product grid -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:2px;" class="lgx-newin-grid">
      {%- assign collection = section.settings.collection -%}
      {%- for product in collection.products limit: section.settings.limit -%}
        <a href="{{ product.url }}" style="text-decoration:none;display:block;position:relative;overflow:hidden;background:#111;cursor:pointer;" class="lgx-newin-card">
          <div style="aspect-ratio:3/4;overflow:hidden;position:relative;">
            <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94);" class="lgx-newin-img">
            {%- if product.compare_at_price > product.price -%}
              <div style="position:absolute;top:12px;left:12px;background:#ff4444;color:#fff;font-size:8px;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;padding:4px 10px;">Sale</div>
            {%- elsif product.tags contains 'New' -%}
              <div style="position:absolute;top:12px;left:12px;background:#fff;color:#000;font-size:8px;font-weight:800;letter-spacing:0.18em;text-transform:uppercase;padding:4px 10px;">New</div>
            {%- endif -%}
          </div>
          <div style="padding:16px 14px 20px;background:#0d0d0d;">
            <p style="font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:#71717a;margin-bottom:4px;font-weight:600;">{{ collection.title | escape }}</p>
            <p style="font-size:14px;font-weight:600;color:#fff;margin-bottom:6px;">{{ product.title }}</p>
            <p style="font-size:13px;color:#a1a1aa;">{{ product.price | money_without_trailing_zeros }}</p>
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..4) -%}
          <div style="background:#111; aspect-ratio:3/4;">{{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full opacity-20' }}</div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <!-- CTA below grid -->
    {%- if section.settings.button_label != blank -%}
      <div style="text-align:center;padding:48px 0 80px;position:relative;z-index:2;">
        <a href="{{ collection.url | default: routes.all_products_collection_url }}" style="display:inline-block;background:#fff;color:#000;padding:16px 48px;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;font-family:inherit;text-decoration:none;transition:background 0.2s,transform 0.15s;" onmouseover="this.style.background='#e5e5e5';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#fff';this.style.transform='none'">{{ section.settings.button_label | escape }} →</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .lgx-newin-card:hover .lgx-newin-img { transform: scale(1.06); }
  @media(max-width:767px) { .lgx-newin-grid { grid-template-columns: repeat(2,1fr) !important; } }
</style>

{% schema %}
{
  "name": "LegginX New In",
  "settings": [
    {
      "type": "text",
      "id": "watermark",
      "label": "Watermark Text",
      "default": "New In"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Product Limit",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop All New"
    }
  ],
  "presets": [
    {
      "name": "LegginX New In"
    }
  ]
}
{% endschema %}
