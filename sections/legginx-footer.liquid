<footer class="bg-black py-20 px-8 border-t border-white/5 font-['Outfit'] w-full relative z-20" data-section-id="{{ section.id }}">
  <div class="max-w-7xl mx-auto grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 text-left">
    <div>
      <a href="{{ routes.root_url }}" class="flex items-center gap-3 mb-6 group">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '100x' }}" class="w-7 h-7 flex-shrink-0" alt="{{ shop.name }}">
        {%- else -%}
          <img src="{{ 'logo.png' | asset_url }}" class="w-7 h-7 flex-shrink-0" alt="{{ shop.name }}">
        {%- endif -%}
        <span class="text-white text-xs font-bold uppercase tracking-[0.3em]">{{ shop.name }}</span>
      </a>
    </div>
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'link_list' -%}
          <div>
            <h4 class="text-white text-[10px] font-bold uppercase tracking-[0.3em] mb-8">{{ block.settings.heading | escape }}</h4>
            <ul class="space-y-4 text-zinc-500 text-xs font-light tracking-wider">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}" class="hover:text-white transition-colors uppercase">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
      {%- endcase -%}
    {%- endfor -%}

    <div>
      <h4 class="text-white text-[10px] font-bold uppercase tracking-[0.3em] mb-8">SOCIAL</h4>
      <div class="flex gap-6">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" class="text-zinc-500 hover:text-white transition-colors">
            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
  
  <div class="mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
    <p class="text-[10px] text-zinc-600 uppercase tracking-widest">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. ALL RIGHTS RESERVED. {{ section.settings.copyright_text }}</p>
    <div class="flex gap-4">
      {%- if section.settings.show_payment_icons -%}
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'h-4 opacity-30' }}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "LegginX Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "DESIGNED FOR PERFORMANCE."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      }
    ]
  }
}
{% endschema %}
