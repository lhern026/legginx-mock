<section style="width:100%;display:grid;grid-template-columns:1fr 1fr;min-height:82vh;background:#000;" class="font-['Outfit'] lgx-edit-grid" data-section-id="{{ section.id }}">

  <!-- Left: editorial image -->
  <div style="position:relative;overflow:hidden;min-height:clamp(400px,60vw,820px);">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.heading | escape }}" style="width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.image_position }};display:block;transition:transform 12s ease-out;" id="lgx-edit-img-{{ section.id }}" class="lgx-edit-img">
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
    {%- endif -%}
    
    <!-- Gradient overlay -->
    <div style="position:absolute;inset:0;background:linear-gradient(to right,transparent 55%,rgba(0,0,0,0.5) 100%);"></div>
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.6) 0%,transparent 40%);"></div>
    
    <!-- Floating label -->
    <div style="position:absolute;bottom:32px;left:28px;">
      <span style="font-size:8px;letter-spacing:0.35em;text-transform:uppercase;color:rgba(255,255,255,0.45);font-weight:600;">{{ section.settings.label | escape }}</span>
    </div>
  </div>

  <!-- Right: product list panel -->
  <div style="background:#0a0a0a;padding:clamp(48px,7vw,96px) clamp(28px,5vw,72px);display:flex;flex-direction:column;justify-content:center;border-left:1px solid rgba(255,255,255,0.05);">
    <h2 style="font-size:clamp(2.2rem,4.5vw,4rem);font-weight:800;text-transform:uppercase;color:#fff;line-height:0.92;letter-spacing:-0.03em;margin-bottom:48px;">{{ section.settings.heading | escape }}</h2>

    <!-- Product list -->
    <div style="display:flex;flex-direction:column;gap:0;border-top:1px solid rgba(255,255,255,0.07);">
      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank -%}
          {%- assign product = block.settings.product -%}
          <a href="{{ product.url }}" style="display:flex;align-items:center;justify-content:space-between;padding:18px 0;border-bottom:1px solid rgba(255,255,255,0.07);text-decoration:none;transition:background 0.2s;gap:16px;" class="lgx-edit-item">
            <div style="display:flex;align-items:center;gap:14px;">
              <div style="width:44px;height:52px;overflow:hidden;flex-shrink:0;background:#111;">
                <img src="{{ product.featured_image | img_url: '100x' }}" style="width:100%;height:100%;object-fit:cover;display:block;">
              </div>
              <div>
                <p style="font-size:13px;font-weight:600;color:#fff;margin-bottom:2px;">{{ product.title }}</p>
                <p style="font-size:11px;color:#71717a;">{{ block.settings.sub_text | default: 'Limited Edition' }}</p>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:20px;flex-shrink:0;">
              <span style="font-size:13px;color:#fff;font-weight:500;">{{ product.price | money_without_trailing_zeros }}</span>
              <span style="font-size:18px;color:rgba(255,255,255,0.25);transition:color 0.2s;" class="lgx-edit-arrow">→</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" style="display:inline-block;margin-top:40px;background:#fff;color:#000;padding:16px 40px;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;font-family:inherit;text-decoration:none;transition:background 0.2s,transform 0.15s;align-self:flex-start;" onmouseover="this.style.background='#e5e5e5';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#fff';this.style.transform='none'">{{ section.settings.button_label | escape }} →</a>
    {%- endif -%}
  </div>

</section>

<style>
  .lgx-edit-item:hover .lgx-edit-arrow { color: #fff !important; }
  @media(max-width:767px) {
    .lgx-edit-grid { grid-template-columns: 1fr !important; }
    .lgx-edit-img { transform: scale(1) !important; animation: none !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const img = document.getElementById('lgx-edit-img-{{ section.id }}');
    if (img) { img.style.transform = 'scale(1)'; }
  });
</script>

{% schema %}
{
  "name": "LegginX Editorial Edit",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Floating Label",
      "default": "FW26 · Limited Series"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Edit"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Featured Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "sub_text",
          "label": "Subtext (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LegginX Editorial Edit",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
